# MoneyPrinterTurbo Environment Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control - it may contain sensitive data

# ============================================================================
# Deployment Mode
# ============================================================================
# Set to "dev" for development mode (shows dev indicator in UI)
# Set to "prod" for production mode
MPT_MODE=prod

# ============================================================================
# API Configuration
# ============================================================================
# Internal API base URL (used by WebUI to communicate with API)
# For Docker: use service name (e.g., http://moneyprinterturbo-dev-api:8080)
# For local: use localhost (e.g., http://localhost:8080)
MPT_API_BASE_URL=http://localhost:8080

# Public API base URL (used for external/browser access to generated videos)
# This should be the externally accessible URL
# For Docker on remote host: use the host IP (e.g., http://192.168.0.116:8089)
# For local: same as MPT_API_BASE_URL
MPT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional API key for WebUI authentication
# Leave empty to disable API key requirement
MPT_API_KEY=

# ============================================================================
# Docker Configuration
# ============================================================================
# Timezone for containers
TZ=America/New_York

# User ID and Group ID for container processes
# Set to your host user/group to avoid permission issues
# Run 'id -u' and 'id -g' to get your values
PUID=1000
PGID=1000

# Python unbuffered output (recommended for Docker logs)
PYTHONUNBUFFERED=1

# ============================================================================
# Path Configuration
# ============================================================================
# Repository directory (where MoneyPrinterTurbo code is located)
# For Docker: absolute path on host
MPT_REPO_DIR=/mnt/data/repos/MoneyPrinterTurbo-openai-tts

# Docker data directory (for config, storage, etc.)
DOCKERDIR=/opt/docker

# ============================================================================
# CORS Configuration
# ============================================================================
# Allowed CORS origins (comma-separated)
# "*" allows all origins - RESTRICT THIS IN PRODUCTION!
# Example: "http://localhost:3000,https://yourdomain.com"
CORS_ALLOWED_ORIGINS=*

# ============================================================================
# Optional: Streamlit Configuration Overrides
# ============================================================================
# These override settings in webui/.streamlit/config.toml
# STREAMLIT_SERVER_HEADLESS=true
# STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
# STREAMLIT_SERVER_ENABLE_CORS=true
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ============================================================================
# Optional: External Service URLs
# ============================================================================
# AllTalk TTS service (if using external TTS)
# ALLTALK_BASE_URL=http://192.168.0.116:7851

# Ollama service (if using external LLM)
# Note: Port 11436 is your host port mapping to Ollama's container port 11434
# For Docker: use http://host.docker.internal:11436/v1
# For direct connection: http://192.168.0.116:11436/v1
# OLLAMA_BASE_URL=http://192.168.0.116:11436/v1

# Redis service (if using external Redis for task state)
# REDIS_HOST=192.168.0.116
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================================================
# Optional: Performance Tuning
# ============================================================================
# Maximum concurrent video generation tasks
# MAX_CONCURRENT_TASKS=5

# FFmpeg thread count (0 = auto)
# FFMPEG_THREADS=0

# ============================================================================
# Optional: Development/Debugging
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Enable detailed error messages
# DEBUG=false
